---
import { Icon } from "astro-icon/components";

type Props = {
  socials: Array<{
    icon: string;
    ariaLabel: string;
    href: string;
  }>;
  variant?: "hero" | "footer";
};

const { socials, variant = "hero" } = Astro.props;

const isFooter = variant === "footer";
---

{
  isFooter ? (
    <div class="flex items-center gap-4">
      {
        socials.map(function displaySocialIcon(info) {
          return (
            <a
              target="_blank"
              href={info.href}
              class="group/social relative flex size-10 items-center justify-center rounded-full bg-gray-100 transition-all duration-300 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600"
              aria-label={info.ariaLabel}
            >
              <Icon
                name={info.icon}
                class="size-5 text-gray-500 transition-colors duration-300 group-hover/social:text-blue-600 dark:text-gray-400 dark:group-hover/social:text-blue-400"
              />
            </a>
          );
        })
      }
    </div>
  ) : (
    <div
      class="mb-12 translate-y-8 transform animate-[fadeInUp_1s_ease-out_0.8s_forwards] opacity-0 transition-all duration-1000 ease-out"
    >
      <div class="flex justify-center gap-6">
        {
          socials.map(function displaySocialIcon(info) {
            return (
              <a
                target="_blank"
                href={info.href}
                class="group/social relative transform rounded-full bg-white/80 p-4 shadow-lg backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:scale-110 hover:shadow-xl"
                aria-label={info.ariaLabel}
              >
                <div class="absolute inset-0 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 opacity-0 transition-opacity duration-300 group-hover/social:opacity-20" />
                <Icon
                  name={info.icon}
                  class="relative z-10 size-8 text-gray-600 transition-colors duration-300 group-hover/social:text-blue-600"
                />
              </a>
            );
          })
        }
      </div>
    </div>
  )
}
