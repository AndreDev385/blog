---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Layout from "@/layouts/Layout.astro";
import type { CollectionEntry } from "astro:content";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import SkillBadge from "@/components/SkillBadge.astro";
import { skillIconMap, type Skill } from "@/lib/skillIconMap";
import ChapterHeading from "./ChapterHeading.astro";
import TestimonialCard from "./TestimonialCard.astro";
import { ImageGallery } from "./ImageGallery";
import BruschiRentalsLogo from "@/assets/bruschi_rentals.svg";
import BrDashboard1 from "@/assets/br_dashboard1.png";
import BrDashboard2 from "@/assets/br_dashboard2.png";
import BrDashboard3 from "@/assets/br_dashboard3.png";
import { resolvePhoto } from "@/lib/resolvePhoto";

/* ─────────────────────────────────────────────
   Intent: A case study page for a portfolio.
   A recruiter or potential client wants to
   understand the tangible impact of this project.
   They need to see: what problem existed →
   how it was solved → what results came from it.
   The page should feel like an editorial case
   study — authoritative, evidence-driven,
   narrative.

   Palette: White canvas, emerald for success/
   results, amber for problem/tension, cool
   slate/blue for technical depth. No decorative
   color — every hue carries meaning.

   Depth: Gradient-treated icon containers with
   white icons for chapter headings. Accent left
   borders at 500 saturation. Impact strip cards
   get a subtle gradient + shadow. Otherwise
   borders-only for clean editorial feel.

   Typography: font-bold headlines (gray-900),
   comfortable body (gray-600), font-extrabold
   impact numbers (emerald-900).

   Spacing base: 4px (Tailwind default).
   Major sections: mb-16-20. Inner cards: p-5.
   Mobile-first: all grids collapse to 1-2 cols.
   ───────────────────────────────────────────── */

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type Project = CollectionEntry<"projects">;

const { project, headings } = Astro.props as {
  project: Project;
  headings: { depth: number; slug: string; text: string }[];
};

const logoMap: Record<string, ImageMetadata> = {
  "bruschi_rentals.svg": BruschiRentalsLogo,
};

const projectLogo = project.data.logo
  ? logoMap[project.data.logo.split("/").pop() || ""]
  : undefined;

const backUrl = lang === "es" ? "/es/" : "/en/";

// Does this project have the narrative sections for a case study?
const hasNarrativeSections =
  project.data.problem ||
  project.data.archAreas ||
  project.data.benefits ||
  project.data.beforeAfter;

// Impact metrics: the beforeAfter improvements are the transformation story.
// These become the visual "impact strip" — the signature of this layout.
const impactMetrics = (project.data.beforeAfter ?? []).slice(0, 4);

// Architecture area accent colors — each area gets a signature tint
type AreaAccent = {
  label: string;
  iconBg: string;
  icon: string;
  numberBg: string;
  numberText: string;
};
const areaAccents: AreaAccent[] = [
  {
    label: "01",
    iconBg: "from-emerald-500 to-emerald-400",
    icon: "mdi:earth",
    numberBg: "bg-emerald-100",
    numberText: "text-emerald-700",
  },
  {
    label: "02",
    iconBg: "from-blue-500 to-indigo-500",
    icon: "mdi:monitor-dashboard",
    numberBg: "bg-blue-100",
    numberText: "text-blue-700",
  },
  {
    label: "03",
    iconBg: "from-amber-500 to-orange-500",
    icon: "mdi:server",
    numberBg: "bg-amber-100",
    numberText: "text-amber-700",
  },
];

// ── Image lookup map ─────────────────────────────
const imageLookup: Record<string, ImageMetadata> = {
  "br_dashboard1.png": BrDashboard1,
  "br_dashboard2.png": BrDashboard2,
  "br_dashboard3.png": BrDashboard3,
};

function resolveProjectImage(imgPath: string): ImageMetadata | undefined {
  const filename = imgPath.split("/").pop() || "";
  return imageLookup[filename];
}

// ── Tech string → Skill mapping ─────────────────
// Normalises content tech strings (e.g. "Astro 5")
// into Skill objects from skillIconMap, with a
// generic fallback for unmatched entries.

const techCache = new Map<string, Skill>();

function toSkill(techName: string): Skill {
  const cached = techCache.get(techName);
  if (cached) return cached;

  // Normalise: lowercase, strip version numbers ("astro 5" → "astro")
  const normalised = techName
    .toLowerCase()
    .trim()
    .replace(/[\s-]+v?\d+(\.\d+)*(\s.*)?$/, "")
    .trim()
    .replace(/\s+\d+(\.\d+)*.*$/, "")
    .trim();

  // Direct key match
  if (normalised in skillIconMap) {
    const skill = skillIconMap[normalised as keyof typeof skillIconMap];
    techCache.set(techName, skill);
    return skill;
  }

  // Multi-word specials
  const specialMappings: Record<string, string> = {
    "tailwind css": "tailwindcss",
    "tailwindcss": "tailwindcss",
    "react native": "react native",
    "postgresql": "postgresql",
  };
  if (normalised in specialMappings) {
    const mapped = specialMappings[normalised];
    if (mapped in skillIconMap) {
      const skill = skillIconMap[mapped as keyof typeof skillIconMap];
      techCache.set(techName, skill);
      return skill;
    }
  }

  // Fallback: generic code icon
  const fallback: Skill = { name: techName, icon: "mdi:code-tags" };
  techCache.set(techName, fallback);
  return fallback;
}


---

<Layout title={project.data.title} description={project.data.description}>
  {/* ─── Structured Data ─── */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": project.data.title,
    "description": project.data.description,
    "url": project.data.link
      ? project.data.link
      : `https://andre-izarra.netlify.app${Astro.url.pathname}`,
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
    },
  })} />

  <div class="mx-auto max-w-5xl px-6 py-10 md:px-4 lg:px-2">
    {/* ─── Back ─── */}
    <a
      href={backUrl}
      class="group/back mb-8 inline-flex items-center gap-2 text-sm font-medium text-gray-400 transition-colors duration-200 hover:text-emerald-600"
    >
      <Icon
        name="mdi:arrow-left"
        class="size-4 transition-transform duration-200 group-hover/back:-translate-x-1"
      />
      <span>{lang === "es" ? "Volver al inicio" : "Back to home"}</span>
    </a>

    {/* ════════════════════════════════════════
        HEADER
       ════════════════════════════════════════ */}
    <header class="mb-12">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
        {/* Logo — hidden on smallest mobile to save space */}
        {projectLogo && (
          <Image
            src={projectLogo}
            width={64}
            height={64}
            alt={`${project.data.title} logo`}
            class="hidden size-16 flex-shrink-0 rounded-xl object-contain ring-1 ring-gray-100 sm:block"
          />
        )}

        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              {/* Hero image placeholder — add project.data.image to schema to use */}
              {/* {project.data.image && (
                <img
                  src={project.data.image}
                  alt={`Hero image for ${project.data.title}`}
                  class="mb-4 w-full rounded-xl object-cover"
                />
              )} */}

              <span class="inline-block rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-emerald-700">
                {lang === "es" ? "Caso de Estudio" : "Case Study"}
              </span>

              <h1 class="mt-3 text-2xl font-bold text-gray-900 md:text-4xl">
                {project.data.title}
              </h1>
            </div>

            {project.data.link && (
              <a
                href={project.data.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group/btn inline-flex flex-shrink-0 items-center gap-2 rounded-full border border-emerald-200 px-4 py-2 text-sm font-medium text-emerald-700 transition-all duration-200 hover:bg-emerald-50 hover:shadow-sm"
              >
                <Icon name="mdi:open-in-new" class="size-4" />
                <span class="hidden sm:inline">
                  {lang === "es" ? "Sitio en vivo" : "Live site"}
                </span>
              </a>
            )}
          </div>

          <p class="mt-4 text-base leading-relaxed text-gray-600 md:text-lg">
            {project.data.description}
          </p>
        </div>
      </div>
    </header>

    {/* ════════════════════════════════════════
        NARRATIVE SECTIONS
       ════════════════════════════════════════ */}
    {hasNarrativeSections && (
      <>
        {/* ─── 1. IMPACT STRIP — The Signature ─── */}
        {impactMetrics.length > 0 && (
          <section class="mb-16 md:mb-20">
            <div class="mb-6">
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600">
                {lang === "es" ? "Impacto Clave" : "Key Results"}
              </span>
              <div class="mt-2 h-0.5 w-16 rounded-full bg-gradient-to-r from-emerald-400 to-emerald-300" />
            </div>

            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
              {impactMetrics.map((item, i) => (
                <div
                  class="group relative rounded-xl border border-emerald-100 bg-gradient-to-br from-emerald-50 via-white to-emerald-50/30 p-4 shadow-sm transition-all duration-200 hover:border-emerald-300 hover:shadow-md"
                >
                  {/* Thick gradient top accent */}
                  <div class="absolute inset-x-0 top-0 h-1 rounded-t-xl bg-gradient-to-r from-emerald-500 to-emerald-400" />

                  <span class="text-[11px] font-semibold uppercase tracking-[0.15em] text-emerald-600">
                    {item.aspect}
                  </span>
                  <p class="mt-2 text-xs font-bold leading-snug text-emerald-900 sm:text-sm">
                    {item.improvement}
                  </p>

                  {/* Decorative index */}
                  <span class="absolute bottom-2 right-3 text-[10px] font-bold text-emerald-200">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* ─── 2. PRODUCT IN ACTION ─── */}
        {project.data.images && project.data.images.length > 0 && (
          <section class="mb-16 md:mb-20">
            <ChapterHeading
              chapter={{
                key: "gallery",
                icon: "mdi:image-multiple-outline",
                gradient: "from-purple-500 to-violet-500",
                borderColor: "border-l-purple-500",
                title: lang === "es" ? "El Producto en Acción" : "Product in Action",
              }}
            />

            <div class="mt-6 pl-5 md:pl-9">
              <p class="mb-6 text-sm leading-relaxed text-gray-500">
                {lang === "es"
                  ? "Capturas de pantalla del panel de administración en funcionamiento."
                  : "Screenshots of the admin dashboard in action."}
              </p>

              {
                /* Resolve images into GalleryImage shape */
                (() => {
                  const galleryImages = (project.data.images ?? []).map((imgPath, i) => ({
                    src: resolveProjectImage(imgPath)?.src ?? imgPath,
                    alt: `${project.data.title} dashboard screenshot ${i + 1}`,
                    caption:
                      lang === "es"
                        ? `Vista ${i + 1} del panel`
                        : `Dashboard view ${i + 1}`,
                  }));
                  return <ImageGallery images={galleryImages} client:load />;
                })()
              }
            </div>
          </section>
        )}

        {/* ─── 3. THE PROBLEM ─── */}
        {project.data.problem && (
          <section class="mb-16 md:mb-20">
            <ChapterHeading
              chapter={{
                key: "problem",
                icon: "mdi:alert-circle-outline",
                gradient: "from-amber-500 to-orange-500",
                borderColor: "border-l-amber-500",
                title: lang === "es" ? "El Problema" : "The Problem",
              }}
            />

            <div class="mt-6 pl-5 md:pl-9">
              <p class="text-base leading-relaxed text-gray-600 md:text-lg">
                {project.data.problem}
              </p>
            </div>

            {/* Image slot — add images to the problem section in the future */}
            {/* <figure class="mt-8 overflow-hidden rounded-xl border border-gray-100">
              <img src="..." alt="..." class="w-full object-cover" />
              <figcaption class="px-4 py-2 text-xs text-gray-400">...</figcaption>
            </figure> */}
          </section>
        )}

        {/* ─── 3. THE SOLUTION ─── */}
        {(project.data.role || project.data.archAreas) && (
          <section class="mb-16 md:mb-20">
            <ChapterHeading
              chapter={{
                key: "solution",
                icon: "mdi:lightbulb-outline",
                gradient: "from-blue-500 to-indigo-500",
                borderColor: "border-l-blue-500",
                title: lang === "es" ? "La Solución" : "The Solution",
              }}
            />

            <div class="mt-6 space-y-6 pl-5 md:pl-9">
              {/* Role as context — part of the solution story */}
              {project.data.role && (
                <div class="flex items-start gap-3 rounded-lg border border-blue-100 bg-gradient-to-br from-blue-50 via-white to-blue-50/30 p-4 shadow-sm">
                  <div class="flex size-9 flex-shrink-0 items-center justify-center rounded-full bg-white shadow-sm ring-1 ring-blue-100">
                    <Icon name="mdi:account-tie" class="size-5 text-blue-500" />
                  </div>
                  <div class="min-w-0">
                    <span class="text-xs font-semibold uppercase tracking-wider text-blue-500">
                      {lang === "es" ? "Mi Rol" : "My Role"}
                    </span>
                    <p class="mt-1 text-sm leading-relaxed text-gray-600">
                      {project.data.role}
                    </p>
                  </div>
                </div>
              )}

              {/* Architecture areas — how the system works */}
              {project.data.archAreas && project.data.archAreas.length > 0 && (
                <div class="space-y-5">
                  {project.data.archAreas.map((area, i) => {
                    const accent = areaAccents[i % areaAccents.length];
                    return (
                      <div class="overflow-hidden rounded-xl border border-gray-100 bg-white transition-all duration-200 hover:border-gray-200 hover:shadow-sm">
                        {/* Area header */}
                        <div class="flex items-start gap-4 border-b border-gray-50 p-5">
                          <span
                            class={`flex size-7 flex-shrink-0 items-center justify-center rounded-md text-xs font-bold ${accent.numberBg} ${accent.numberText}`}
                          >
                            {accent.label}
                          </span>
                          <div class="min-w-0 flex-1">
                            <h3 class="font-bold text-gray-900">{area.title}</h3>
                            <p class="mt-1 text-sm leading-relaxed text-gray-500">
                              {area.description}
                            </p>
                          </div>
                        </div>

                        <div class="p-5">
                          {/* Image placeholder per area */}
                          {/* <img
                            src="..."
                            alt={`Screenshot of ${area.title}`}
                            class="mb-5 w-full rounded-lg border border-gray-100 object-cover"
                          /> */}

                          {/* Features + Tech side by side on wider screens */}
                          <div class="grid gap-6 md:grid-cols-2">
                            {/* Features */}
                            <div>
                              <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
                                {lang === "es" ? "Características" : "Features"}
                              </h4>
                              <ul class="space-y-2">
                                {area.features.map((feature) => (
                                  <li class="flex items-start gap-2 text-sm text-gray-600">
                                    <Icon
                                      name="mdi:check-circle"
                                      class="mt-0.5 size-4 flex-shrink-0 text-emerald-500"
                                    />
                                    <span>{feature}</span>
                                  </li>
                                ))}
                              </ul>
                            </div>

                            {/* Tech used in this area */}
                            <div>
                              <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
                                {lang === "es" ? "Tecnologías" : "Tech"}
                              </h4>
                              <div class="flex flex-wrap gap-2">
                                {area.tech.map((t) => (
                                  <SkillBadge skill={toSkill(t)} />
                                ))}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          </section>
        )}

        {/* ─── 4. THE TRANSFORMATION (Before / After) ─── */}
        {project.data.beforeAfter && project.data.beforeAfter.length > 0 && (
          <section class="mb-16 md:mb-20">
            <ChapterHeading
              chapter={{
                key: "transformation",
                icon: "mdi:swap-horizontal-bold",
                gradient: "from-emerald-500 to-teal-500",
                borderColor: "border-l-emerald-500",
                title: lang === "es" ? "La Transformación" : "The Transformation",
              }}
            />

            <div class="mt-6 space-y-5 pl-5 md:pl-9">
              {project.data.beforeAfter.map((item) => (
                <div class="overflow-hidden rounded-xl border border-gray-100 bg-white transition-all duration-200 hover:border-gray-200 hover:shadow-sm">
                  {/* Aspect title */}
                  <div class="border-b border-gray-50 bg-gradient-to-r from-gray-50 to-white px-5 py-3">
                    <h3 class="text-sm font-bold text-gray-900">{item.aspect}</h3>
                  </div>

                  {/* Before | After — stacked on mobile, side-by-side on tablet+ */}
                  <div class="grid divide-y md:grid-cols-2 md:divide-x md:divide-y-0">
                    {/* Before */}
                    <div class="bg-gradient-to-br from-amber-50/40 to-white p-5">
                      <div class="mb-2 inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-700">
                        <Icon name="mdi:close-circle" class="size-3.5" />
                        {lang === "es" ? "Antes" : "Before"}
                      </div>
                      <p class="mt-2 text-sm leading-relaxed text-gray-600">
                        {item.before}
                      </p>

                      {/* Image slot — before screenshot */}
                      {/* <img src="..." alt="Before" class="mt-3 rounded-lg border border-gray-100" /> */}
                    </div>

                    {/* After */}
                    <div class="bg-gradient-to-br from-emerald-50/40 to-white p-5">
                      <div class="mb-2 inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-700">
                        <Icon name="mdi:check-circle" class="size-3.5" />
                        {lang === "es" ? "Después" : "After"}
                      </div>
                      <p class="mt-2 text-sm leading-relaxed text-gray-600">
                        {item.after}
                      </p>

                      {/* Image slot — after screenshot */}
                      {/* <img src="..." alt="After" class="mt-3 rounded-lg border border-gray-100" /> */}
                    </div>
                  </div>

                  {/* Improvement banner */}
                  {item.improvement && (
                    <div class="flex items-center gap-2.5 border-t border-gray-50 bg-gradient-to-r from-emerald-500/10 to-teal-500/10 px-5 py-3">
                      <div class="flex size-6 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-teal-500 shadow-sm">
                        <Icon
                          name="mdi:lightning-bolt"
                          class="size-3.5 text-white"
                        />
                      </div>
                      <span class="text-sm font-bold text-emerald-800">
                        {item.improvement}
                      </span>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        {/* ─── 5. KEY BENEFITS ─── */}
        {project.data.benefits && project.data.benefits.length > 0 && (
          <section class="mb-16 md:mb-20">
            <ChapterHeading
              chapter={{
                key: "benefits",
                icon: "mdi:gift-outline",
                gradient: "from-teal-500 to-emerald-500",
                borderColor: "border-l-teal-500",
                title: t("projects.benefits"),
              }}
            />

            <div class="mt-6 grid gap-4 pl-5 sm:grid-cols-2 md:pl-9">
              {project.data.benefits.map((benefit) => (
                <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 transition-all duration-200 hover:border-teal-200 hover:shadow-sm">
                  <div class="mt-1 flex size-10 flex-shrink-0 items-center justify-center rounded-lg bg-gradient-to-br from-teal-100 to-emerald-100 shadow-sm">
                    {benefit.icon ? (
                      <Icon name={benefit.icon} class="size-5 text-teal-600" />
                    ) : (
                      <Icon name="mdi:check-circle" class="size-5 text-teal-600" />
                    )}
                  </div>
                  <div class="min-w-0">
                    <h3 class="font-semibold text-gray-900">{benefit.title}</h3>
                    <p class="mt-1 text-sm leading-relaxed text-gray-500">
                      {benefit.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* ─── 6. TECH STACK ─── */}
        {project.data.techStack && project.data.techStack.length > 0 && (
          <section class="mb-16 md:mb-20">
            <div class="mb-5 flex items-center gap-3 pl-5 md:pl-9">
              <Icon name="mdi:code-tags" class="size-5 text-gray-400" />
              <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400">
                {lang === "es" ? "Stack Tecnológico" : "Tech Stack"}
              </h2>
            </div>
            <div class="flex flex-wrap gap-2 pl-5 md:pl-9">
              {project.data.techStack.map((tech) => (
                <SkillBadge skill={toSkill(tech)} />
              ))}
            </div>
          </section>
        )}

        {/* ─── 7. TESTIMONIALS ─── */}
        {project.data.testimonials && project.data.testimonials.length > 0 && (
          <section class="mb-16 md:mb-20">
            <ChapterHeading
              chapter={{
                key: "testimonials",
                icon: "mdi:message-text",
                gradient: "from-emerald-500 to-teal-500",
                borderColor: "border-l-emerald-500",
                title:
                  lang === "es" ? "Lo Que Dicen" : "What People Say",
              }}
            />

            <div class="mt-6 space-y-5 pl-5 md:pl-9">
              {project.data.testimonials.map((t) => (
                <TestimonialCard
                  quote={t.quote}
                  author={t.author}
                  role={t.role}
                  company={t.company}
                  photo={resolvePhoto(t.photo)}
                  linkedin={t.linkedin}
                />
              ))}
            </div>
          </section>
        )}
      </>
    )}

    {/* ════════════════════════════════════════
        NARRATIVE BODY (markdown slot)
       ════════════════════════════════════════ */}
    <div class="prose prose-lg border-t border-gray-100 pt-10">
      <slot />
    </div>

    {/* ════════════════════════════════════════
        CTA
       ════════════════════════════════════════ */}
    {project.data.link && (
      <div class="mt-12 text-center">
        <a
          href={project.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group/btn inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-emerald-600 to-teal-600 px-8 py-3 font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl"
        >
          <span>
            {lang === "es" ? "Visitar el sitio" : "Visit the site"}
          </span>
          <Icon
            name="mdi:open-in-new"
            class="size-5 transition-transform duration-300 group-hover/btn:translate-x-0.5"
          />
        </a>
      </div>
    )}
  </div>

</Layout>
