---
import { Icon } from "astro-icon/components";

import ModeToggle from "@/components/ModeToggle.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const WHATSAPP_URL = "https://wa.me/584241756082";
const LINKEDIN_URL = "https://www.linkedin.com/in/andr%C3%A9-izarra/";
---

<!-- Hero -->
<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100"
>
  <div class="mx-auto max-w-7xl px-6 text-center">
    <!-- Greeting -->
    <h2 class="mb-2 text-3xl font-semibold text-gray-500">
      {t("hero.greet")}{" "}
      <span class="text-blue-900">André Izarra</span>
    </h2>

    <!-- Main Title -->
    <h1
      class="mb-10 bg-gradient-to-r from-gray-900 via-blue-800 to-purple-800 bg-clip-text text-5xl leading-tight font-bold text-transparent md:text-7xl lg:text-8xl"
    >
      {t("hero.role1")}{" "}
      {t("hero.role2")}
    </h1>

    <!-- Mode Toggle -->
    <div class="mb-8">
      <ModeToggle />
    </div>

    <!-- Dual CTAs -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <!-- Freelance CTA -->
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-freelance inline-flex items-center gap-2.5 rounded-full bg-gradient-to-r from-blue-600 to-purple-600 px-7 py-3 text-sm font-semibold text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
      >
        <Icon name="mdi:whatsapp" class="size-5" />
        <span>{t("hero.cta.freelance")}</span>
      </a>

      <!-- Employee CTA -->
      <a
        href={LINKEDIN_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-employee inline-flex items-center gap-2.5 rounded-full bg-gradient-to-r from-emerald-600 to-teal-600 px-7 py-3 text-sm font-semibold text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
      >
        <Icon name="mdi:linkedin" class="size-5" />
        <span>{t("hero.cta.employee")}</span>
      </a>
    </div>
  </div>
</section>
