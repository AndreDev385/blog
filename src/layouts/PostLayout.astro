---
import "@/styles/markdown.css";
import Layout from "@/layouts/Layout.astro";
import TableOfContent from "@/modules/blog/components/TableOfContent.astro";
import SkillBadge from "@/components/SkillBadge.astro";

import { skillIconMap } from "@/lib/skillIconMap";
import { Author } from "@/components/Author";

import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { formatDate } from "@/modules/blog/utils/formatDate";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { post, headings } = Astro.props;
---

<Layout title={post.data.title} description={post.data.description}>
  <!-- Structured Data: BlogPosting -->
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.date.toISOString(),
      author: {
        "@type": "Person",
        name: "André Izarra",
      },
      image: post.data.image,
      keywords: post.data.tags?.join(", ") || "",
    })}
  />

  <div
    class="mx-auto mt-4 flex max-w-6xl flex-col gap-8 px-6 md:px-4 lg:flex-row lg:justify-center lg:px-2"
  >
    <div class="max-w-[68ch] min-w-0 flex-1">
      <article>
        <header class="relative mb-8">
          <h1 class="text-foreground mb-2 text-4xl font-bold lg:text-5xl">
            {post.data.title}
          </h1>
          <Author
            postedString={`${t("posted.on")} ${formatDate(post.data.date, lang)}`}
          />
          {
            post.data.tags && (
              <div class="mt-2">
                {post.data.tags.map((tag: string) => (
                  <a href={`/${lang}/tags/${tag.toLowerCase()}`}>
                    <SkillBadge
                      skill={skillIconMap[tag as keyof typeof skillIconMap]}
                    />
                  </a>
                ))}
              </div>
            )
          }
        </header>
        <div class="prose prose-lg relative max-w-none">
          <slot />
        </div>
      </article>
    </div>
    <aside class="hidden w-64 flex-shrink-0 lg:block">
      <div class="sticky top-8">
        <TableOfContent headings={headings} />
      </div>
    </aside>
  </div>
</Layout>
