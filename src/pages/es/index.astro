---
import Layout from "@/layouts/Layout.astro";
import ScrollReveal from "@/components/ScrollReveal.astro";

import Hero from "@/modules/portfolio/components/Hero.astro";
// import AboutMe from "@/modules/portfolio/components/AboutMe.astro";
import ProjectsSection from "@/modules/portfolio/components/ProjectsSection.astro";
import TestimonialsSection from "@/modules/portfolio/components/TestimonialsSection.astro";
import ServicesSection from "@/modules/portfolio/components/ServicesSection.astro";
import FaqSection from "@/modules/portfolio/components/FaqSection.astro";
import ExperienceSection from "@/modules/portfolio/components/ExpirienceSection.astro";
---

<Layout
  description="Desarrollador de software full-stack especializado en construir aplicaciones web confiables, APIs REST y soluciones en la nube. Más de 4 años de experiencia entregando software de alto rendimiento."
>
  <Hero />
  <ScrollReveal />
  {/* <AboutMe /> */}

  <div class="mode-container">
    <div data-mode="freelance" class="mode-section" data-section="services">
      <ServicesSection />
    </div>

    <div data-mode="both" class="mode-section" data-section="projects">
      <ProjectsSection />
    </div>

    <div data-mode="both" class="mode-section" data-section="testimonials">
      <TestimonialsSection />
    </div>

    <div data-mode="freelance" class="mode-section" data-section="faq">
      <FaqSection />
    </div>

    <div data-mode="employee" class="mode-section" data-section="experience">
      <ExperienceSection />
    </div>
  </div>
</Layout>
